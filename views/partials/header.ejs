<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Eventify - Premium Events</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar glass">
  <a href="/" class="brand">Eventify</a>
  <div class="nav-links">
    <a href="/">Home</a>
    <% if (user) { %>
      <a href="/events/dashboard">Dashboard</a>
      <a href="/auth/logout" class="btn btn-outline" style="padding: 0.5rem 1rem;">Logout</a>
    <% } else { %>
      <a href="/auth/login">Login</a>
      <a href="/auth/register" class="btn btn-primary" style="padding: 0.5rem 1rem;">Register</a>
    <% } %>
  </div>
</nav>

<div class="container">
  <% if (successMsg) { %>
    <div class="alert alert-success"><%= successMsg %></div>
  <% } %>
  <% if (errorMsg) { %>
    <div class="alert alert-error"><%= errorMsg %></div>
  <% } %>
