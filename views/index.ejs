<%- include('partials/header') %>

<div style="text-align: center; margin-bottom: 3rem;">
  <h1 style="font-size: 3rem; background: -webkit-linear-gradient(#3b82f6, #10b981); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Discover Amazing Events</h1>
  <p style="font-size: 1.2rem;">Book your tickets for the best experiences around.</p>
</div>

<div class="event-grid">
  <% if (events.length > 0) { %>
    <% events.forEach(event => { %>
      <div class="event-card glass">
        <h3><%= event.title %></h3>
        <div class="meta">
          <span>📅 <%= new Date(event.date).toLocaleDateString() %></span><br>
          <span>📍 <%= event.location %></span><br>
          <span>🎟️ <%= event.available_seats %> seats left</span>
        </div>
        <p><%= event.description.substring(0, 100) %>...</p>
        <div class="actions">
          <a href="/events/<%= event.id %>" class="btn btn-primary" style="width: 100%;">View Details</a>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <p style="grid-column: 1/-1; text-align: center;">No events found. Please check back later.</p>
  <% } %>
</div>

<%- include('partials/footer') %>
