<%- include('partials/header') %>

<div class="glass" style="padding: 2rem;">
  <h1 style="margin-bottom: 2rem;">Dashboard</h1>

  <% if (user.role === 'organizer') { %>
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
      <h2>My Hosted Events</h2>
      <a href="/events/create" class="btn btn-primary">+ Create Event</a>
    </div>

    <% if (myEvents.length > 0) { %>
      <div style="overflow-x: auto;">
        <table>
          <thead>
            <tr>
              <th>Title</th>
              <th>Date</th>
              <th>Location</th>
              <th>Available Seats</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% myEvents.forEach(evt => { %>
              <tr>
                <td><%= evt.title %></td>
                <td><%= new Date(evt.date).toLocaleString() %></td>
                <td><%= evt.location %></td>
                <td><%= evt.available_seats %></td>
                <td style="display: flex; gap: 0.5rem;">
                  <a href="/events/<%= evt.id %>" class="btn btn-outline" style="padding: 0.5rem;">View</a>
                  <a href="/events/<%= evt.id %>/edit" class="btn btn-primary" style="padding: 0.5rem;">Edit</a>
                  <form action="/events/<%= evt.id %>?_method=DELETE" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this event?');">
                    <button type="submit" class="btn btn-danger" style="padding: 0.5rem;">Delete</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p>You haven't created any events yet.</p>
    <% } %>

  <% } else { %>
    <h2>My Bookings</h2>
    <% if (bookings.length > 0) { %>
      <div class="event-grid" style="margin-top: 1.5rem;">
        <% bookings.forEach(booking => { %>
          <div class="event-card glass">
            <h3><%= booking.title %></h3>
            <div class="meta">
              <span>📅 <%= new Date(booking.date).toLocaleDateString() %></span><br>
              <span>📍 <%= booking.location %></span><br>
              <span style="color: var(--success)">✅ Booked on <%= new Date(booking.booking_date).toLocaleDateString() %></span>
            </div>
            <div class="actions">
              <a href="/events/<%= booking.id %>" class="btn btn-outline" style="width: 100%;">Event Details</a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p>You haven't booked any events yet. <a href="/">Browse Events</a></p>
    <% } %>
  <% } %>
</div>

<%- include('partials/footer') %>
